# === Production Environment Variables ===

# --- General ---
NODE_ENV=production
# Com Nginx (lydzz.com.br): um único domínio — API e WS passam pelo mesmo host
APP_URL=https://lydzz.com.br
FRONTEND_URL=https://lydzz.com.br

# --- Frontend Build Args (REQUIRED — embutidos no build do Docker) ---
NEXT_PUBLIC_API_URL=https://lydzz.com.br/api
NEXT_PUBLIC_WS_URL=https://lydzz.com.br

# --- Database (Postgres) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=secure_postgres_password
POSTGRES_DB=smarterchat
# Internal Docker URL (keep as is)
DATABASE_URL=postgresql://postgres:secure_postgres_password@postgres:5432/smarterchat?schema=public

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Security ---
# Generate a random 32-char string for JWT
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_this_to_another_long_random_secret
JWT_REFRESH_EXPIRES_IN=30d

# Encryption Key for storing sensitive data (MUST be 32 chars)
ENCRYPTION_KEY=12345678901234567890123456789012
# Master Key for creating companies via /sys-admin
MASTER_SECRET_KEY=lydzz_master_secret_2025

# --- Integrations ---
OPENAI_API_KEY=sk-...
UAZAPI_INSTANCE_TOKEN=your-uazapi-token
